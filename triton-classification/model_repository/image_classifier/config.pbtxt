# Имя модели — должно совпадать с названием папки
name: "image_classifier"

# Бэкенд для исполнения ONNX моделей
backend: "onnxruntime"

# Максимальный размер батча (сколько объектов за один запрос)
max_batch_size: 32

# Динамический батчинг — собирает несколько запросов в один батч
# Это увеличивает throughput при высокой нагрузке
#dynamic_batching {
  # Предпочтительные размеры батчей
  preferred_batch_size: [ 8, 16, 32 ]
  # Максимальная задержка в микросекундах для сбора батча
  max_queue_delay_microseconds: 200000
}

# Настройка исполнения модели
instance_group [
  {
    count: 1        # Количество инстансов модели
    kind: KIND_AUTO # Автовыбор: GPU если есть, иначе CPU
  }
]